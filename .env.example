# Alpaca — paper trading keys start with PK, live keys start with AK
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Database (PostgreSQL — omit to disable trade logging)
DATABASE_URL=postgresql://user:pass@host/db

# Slack webhooks
SLACK_ALERTS_WEBHOOK=https://hooks.slack.com/services/...
SLACK_DECISIONS_WEBHOOK=https://hooks.slack.com/services/...
SLACK_HEALTH_WEBHOOK=https://hooks.slack.com/services/...
SLACK_PERFORMANCE_WEBHOOK=https://hooks.slack.com/services/...
SLACK_SIGNING_SECRET=...

# LLM providers
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
LLM_PROVIDER=anthropic

# Market data
FINNHUB_API_KEY=...

# Optional integrations
QUIVER_API_KEY=...
GROK_API_KEY=...
NOTION_API_KEY=...
NOTION_DATABASE_ID=...
SENTRY_DSN=...
PAGERDUTY_ROUTING_KEY=...
